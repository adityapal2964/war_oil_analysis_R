# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.R text eol=lf
*.r text eol=lf
*.Rmd text eol=lf
*.Rmarkdown text eol=lf
*.html text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.markdown text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.csv text eol=lf

# Data files
*.xlsx binary
*.xls binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Documentation
*.md text eol=lf diff=markdown
